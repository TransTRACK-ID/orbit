POSTGRES_URL=postgres://postgres:postgres@localhost:5432/orbit
NUXT_AUTH_SECRET=your-super-secret-key-at-least-32-chars-long
# Optional: Override the auto-detected auth origin.
# The auth module automatically detects the origin from request headers.
# Set this only when behind a reverse proxy that modifies the Host header.
# AUTH_ORIGIN=http://localhost:3000
# Base64-encoded opencode.json (generate with: base64 -i opencode/opencode.json | tr -d '\n')
OPENCODE_CONFIG_BASE64=your_base64_encoded_opencode_json_here
# Agent runtime selection: opencode (default) | cursor
# Restart the dev server after changing this value.
AGENT_RUNTIME=opencode
# Optional Nuxt runtime overrides (used in production/Docker when config is baked at build time)
# NUXT_AGENT_RUNTIME=cursor
# NUXT_PUBLIC_AGENT_RUNTIME=cursor
# Cursor CLI configuration (required when AGENT_RUNTIME=cursor)
CURSOR_API_KEY=
CURSOR_MODEL=auto
# Fireworks / OpenAI API key for browser QA agent (required if not present in opencode.json)
FIREWORKS_API_KEY=
OPENAI_API_KEY=
